austin-fc-debug.png
mls-*-error*.png

# Scripts (dev-only scrapers and utilities, kept locally)
/scripts/

# One-off test/diagnostic scripts in root
test-*.mjs

# Intermediate/backup data files
data/*.backup.json
data/*-enriched.json
data/*-final.json
data/*-supplement.json
data/transfermarkt-api-responses.json
data/mls-player-stats-2024.json

